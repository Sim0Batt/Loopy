<?xml version="1.0" encoding="utf-8"?>
<AbsoluteLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#3ED183">

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="114dp"
        android:layout_x="167dp"
        android:layout_y="31dp"
        android:fontFamily="@font/alfa_slab_one"
        android:text="Loopy"
        android:textAppearance="@style/TextAppearance.AppCompat.Large"
        android:textSize="70sp" />

    <EditText
        android:id="@+id/emailInput"
        android:layout_width="410dp"
        android:layout_height="wrap_content"
        android:layout_x="0dp"
        android:layout_y="240dp"
        android:ems="10"
        android:inputType="textEmailAddress" />



    <EditText
        android:id="@+id/passwordInput"
        android:layout_width="412dp"
        android:layout_height="wrap_content"
        android:layout_x="0dp"
        android:layout_y="393dp"
        android:ems="10"
        android:inputType="textPassword" />

    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_x="190dp"
        android:layout_y="206dp"
        android:text="Email"
        android:textAlignment="center"
        android:textSize="20sp"
    />

    <TextView
        android:id="@+id/textView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_x="170dp"
        android:layout_y="361dp"
        android:text="Password"
        android:textAlignment="center"
        android:textSize="20sp"
        />

    <ImageButton
        android:id="@+id/submitButton"
        android:layout_width="244dp"
        android:layout_height="83dp"
        android:layout_x="87dp"
        android:layout_y="605dp"
        android:src="@drawable/ic_launcher_foreground" />

    <ImageButton
        android:id="@+id/registerButton"
        android:layout_width="244dp"
        android:layout_height="83dp"
        android:layout_x="87dp"
        android:layout_y="507dp"
        android:src="@drawable/ic_launcher_foreground" />

</AbsoluteLayout>