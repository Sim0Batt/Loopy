<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- The background color of the EditText -->
    <solid android:color="#7A7474" />

    <!-- The radius for the rounded corners -->
    <corners android:radius="100dp" />

    <!-- Optional: Add padding inside the EditText -->
    <padding
        android:left="12dp"
        android:top="12dp"
        android:right="12dp"
        android:bottom="12dp" />

</shape>